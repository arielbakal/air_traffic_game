# Ollama / LLM settings
# When running via Docker Compose, OLLAMA_HOST is overridden automatically to http://ollama:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TEMPERATURE=0.2
OLLAMA_CTX=4096

# Server
PORT=3001

# Game — options: human | ai | collaborative
CONTROLLER_MODE=collaborative
